<%- include('partials/header', { title: 'Dashboard' }) %>
<main class="page-content">
  <section class="section-head">
    <div>
      <span class="eyebrow">Logged in</span>
      <h1>Welcome back, <%= user.username %></h1>
      <p class="muted">Your dashboard only shows the two tools you wanted.</p>
    </div>
  </section>

  <section class="grid two dashboard-grid">
    <a class="tool-card" href="/plato">
      <div class="tool-icon">🎬</div>
      <div>
        <h2>Plato</h2>
        <p>Movies page with a fast little search experience.</p>
      </div>
    </a>

    <a class="tool-card proxy-focus" href="/saturn">
      <div class="tool-icon">🪐</div>
      <div>
        <h2>Saturn</h2>
        <p>Main focus: type a URL and browse it through your own Express proxy route.</p>
      </div>
    </a>
  </section>
</main>
<%- include('partials/footer') %>
