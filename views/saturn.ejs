<%- include('partials/header', { title: 'Saturn' }) %>
<main class="page-content">
  <section class="section-head">
    <div>
      <span class="eyebrow">Web proxy</span>
      <h1>Saturn</h1>
      <p class="muted">Type a URL and Saturn will fetch it through your server, then rewrite common page links and assets.</p>
    </div>
  </section>

  <section class="glass-card proxy-panel">
    <form class="proxy-start" method="GET" action="/saturn/browse">
      <input type="text" name="url" value="<%= startUrl %>" placeholder="https://example.com" />
      <button class="solid-btn" type="submit">Open site</button>
    </form>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <div class="tips-grid">
      <% tips.forEach((tip) => { %>
        <article class="tip-card"><%= tip %></article>
      <% }) %>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
